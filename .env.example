# =============================================================================
# OpenClaw Backup Configuration
# =============================================================================
# Copy this file to .env and edit to match your setup.
# All scripts source this file for configuration.
# =============================================================================

# --- Core Paths ---
# Where OpenClaw lives (the main installation directory)
OPENCLAW_HOME="${HOME}/.openclaw"

# Your OpenClaw workspace (projects, configs, etc.)
OPENCLAW_WORKSPACE="${HOME}/hub-local"

# Where to store local backup artifacts (snapshots, archives)
BACKUP_DIR="${HOME}/backups/openclaw"

# --- Tier 1: Git Backup ---
# Remote to push to (must be configured in your workspace git repo)
GIT_REMOTE="origin"
GIT_BRANCH="main"

# --- Tier 2: Borg / Restic (File-Level Backup) ---
# Borg repository path (Linux)
BORG_REPO="${HOME}/backups/borg/openclaw"
# Borg passphrase (CHANGE THIS — or use BORG_PASSCOMMAND for a keyring)
BORG_PASSPHRASE="CHANGE-ME-TO-SOMETHING-SECURE"
# Borg remote repo (optional, for offsite copy)
BORG_REMOTE_REPO=""

# Restic repository path (macOS)
RESTIC_REPO="${HOME}/backups/restic/openclaw"
RESTIC_PASSWORD="CHANGE-ME-TO-SOMETHING-SECURE"
# Restic remote (e.g., s3:s3.amazonaws.com/bucket, b2:bucket:path, sftp:host:path)
RESTIC_REMOTE_REPO=""

# Prune policy (shared concept across Borg/restic)
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=3

# --- Tier 3: System Image ---
# fsarchiver target directory (Linux)
FSARCHIVER_TARGET="/mnt/nas/backups/images"
# Source device to image (e.g., /dev/sda1, /dev/nvme0n1p2)
FSARCHIVER_SOURCE="/dev/sda1"
# Number of image copies to keep
FSARCHIVER_KEEP=3

# --- Tier 4: Offsite / NAS ---
# NAS connection (user@host:path)
NAS_TARGET="admin@nas.local:/volume1/backups/openclaw"
# NAS SSH port (default 22)
NAS_SSH_PORT=22
# NAS SSH key (optional, falls back to ssh-agent)
NAS_SSH_KEY=""

# Cloud provider for offsite (s3, b2, gdrive, none)
CLOUD_PROVIDER="none"
# S3-compatible settings
S3_BUCKET=""
S3_ENDPOINT=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Backblaze B2
B2_ACCOUNT_ID=""
B2_APPLICATION_KEY=""
B2_BUCKET=""

# --- Logging ---
LOG_DIR="${HOME}/logs/openclaw-backup"
# Log retention in days
LOG_KEEP_DAYS=30

# --- Notifications (optional) ---
# Send notifications on failure? (true/false)
NOTIFY_ON_FAILURE="false"
# Notification method: email, slack, discord, ntfy
NOTIFY_METHOD="email"
# Email recipient
NOTIFY_EMAIL=""
# Webhook URL (for Slack/Discord/ntfy)
NOTIFY_WEBHOOK=""
